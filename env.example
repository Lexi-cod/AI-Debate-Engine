# ============================================================
# AI Decision Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ── Azure OpenAI (required) ──────────────────────────────────
# Your Azure OpenAI resource endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI API key (Key1 or Key2 from the Azure portal)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here

# The deployment name you created in Azure AI Foundry (e.g. gpt-4o)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Optional: separate deployment for web-search calls (defaults to AZURE_OPENAI_DEPLOYMENT)
# Must be a gpt-4o or gpt-4o-mini deployment with web_search_preview enabled
AZURE_OPENAI_SEARCH_DEPLOYMENT=gpt-4o

# API version — must be 2025-01-01-preview or later for web search support
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── LLM Tuning (optional) ────────────────────────────────────
# Temperature for all LLM calls (default: 0.2)
LLM_TEMPERATURE=0.2

# Max tokens per LLM response (default: unlimited by this app)
LLM_MAX_TOKENS=2000

# ── Cosmos DB (required) ─────────────────────────────────────
# Full connection string from Azure Portal → Cosmos DB → Keys
COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your-key==;

# Database and container names (create these in Azure Portal)
COSMOS_DB_NAME=decisions
COSMOS_CONTAINER_NAME=decisions

# ── App Authentication (required in production) ───────────────
# Clients must send this value in the X-API-Key request header.
# Leave blank in local dev to run without authentication (not recommended for production).
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEY=your-secret-api-key-here

# ── CORS (required in production) ────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev default is http://localhost:3000 if this is not set.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ── Azure AI Search (optional) ───────────────────────────────
# Enables searching uploaded/private documents via Azure AI Search.
# Leave blank to skip private-doc search (app still works without it).
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key-here
AZURE_SEARCH_INDEX_NAME=your-index-name

# ── Frontend (Vite / React) ───────────────────────────────────
# These are build-time variables consumed by UI.jsx.
# For Vite: prefix with VITE_
# For Create React App: prefix with REACT_APP_

# Base URL of your backend API (no trailing slash)
VITE_API_BASE=http://localhost:8000
# REACT_APP_API_BASE=http://localhost:8000

# Must match APP_API_KEY above
VITE_API_KEY=your-secret-api-key-here
# REACT_APP_API_KEY=your-secret-api-key-here
